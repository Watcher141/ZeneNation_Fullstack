# =============================================================================
#  ZENENATION — .gitignore
# =============================================================================

# ── Environment files — NEVER COMMIT ──────────────────────────────────────────
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ── Java / Maven / Backend ────────────────────────────────────────────────────
backend/target/
*.class
*.jar
*.war
*.ear
*.iml

# ── Maven wrapper ─────────────────────────────────────────────────────────────
!backend/.mvn/wrapper/maven-wrapper.jar
!backend/.mvn/wrapper/maven-wrapper.properties

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.iws
*.ipr
.classpath
.project
.settings/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
backend/logs/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.tmp
*.bak
*.swp
*.swo